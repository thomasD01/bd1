{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "es2020",
    "moduleResolution": "bundler",
    "jsx": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["./components/*"],
      "@lib/*": ["./lib/*"],
      "@ui/*": ["./components/ui/*"],
      "@hooks/*": ["./hooks/*"],
      "@assets/*": ["./assets/*"]
    }
  },
  "include": ["lib/", "components/", "renderer.ts", "index.html"]
}
