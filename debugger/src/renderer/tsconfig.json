{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "module": "es2020",
    "moduleResolution": "bundler",
    "jsx": "react",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@components/*": ["src/components/*"],
      "@lib/*": ["src/lib/*"],
      "@ui/*": ["src/components/ui/*"],
      "@hooks/*": ["src/hooks/*"],
      "@assets/*": ["./assets/*"]
    }
  },
  "include": ["src/", "renderer.ts", "../../forge.env.d.ts", "../env.ts"]
}
